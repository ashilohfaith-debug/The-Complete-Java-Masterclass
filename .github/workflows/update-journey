name: Update Java Journey Banner

on:
  schedule:
    # Run every day at midnight UTC (adjust time as needed)
    - cron: '0 0 * * *'
  # Allow manual trigger from Actions tab
  workflow_dispatch:

jobs:
  update-banner:
    runs-on: ubuntu-latest
    
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Generate updated banner
        run: python generate_banner.py

      - name: Check if banner changed
        id: banner_check
        run: |
          if git diff --quiet java-journey-banner.svg; then
            echo "changed=false" >> $GITHUB_OUTPUT
          else
            echo "changed=true" >> $GITHUB_OUTPUT
          fi

      - name: Commit and push updated banner
        if: steps.banner_check.outputs.changed == 'true'
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add java-journey-banner.svg
          git commit -m "chore: update journey banner - Day $(date +%d-%m-%Y)"
          git push
